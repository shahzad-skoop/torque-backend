# ---------------------------------------------------------------------------
# Torque Backend - runtime configuration
#
# Copy to .env and fill in real values. This file is the canonical list of
# supported environment variables for both local development and production
# (single-host Cloudflare-Tunnel deployment with shared infra containers).
#
# Secrets (AUTH_*, MINIO_*, DATABASE_URL, REDIS_URL) MUST be overridden in
# production. Do not commit a populated .env.
# ---------------------------------------------------------------------------

# --- App ---------------------------------------------------------------------
APP_NAME=Torque Backend
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

API_V1_PREFIX=/api/v1
# Comma-separated list of allowed browser origins
CORS_ORIGINS=https://usetorque.co,https://www.usetorque.co

# --- Datastores --------------------------------------------------------------
# In production these point at the shared infra containers on the `db` network.
DATABASE_URL=postgresql+psycopg2://torque:torque@torque-postgres:5432/torque_backend
REDIS_URL=redis://torque-redis:6379/0
CELERY_BROKER_URL=redis://torque-redis:6379/1
CELERY_RESULT_BACKEND=redis://torque-redis:6379/2

# --- Object storage (MinIO) --------------------------------------------------
# Use an app-scoped access key/secret, NOT the MinIO root credentials.
MINIO_ENDPOINT=torque-minio:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=torque-artifacts
MINIO_SECURE=false

# --- Skoop auth integration --------------------------------------------------
AUTH_SERVICE_BASE_URL=https://auth-api.skoopsignage.com
AUTH_APP_SECRET=
AUTH_CLIENT_SECRET=
AUTH_AUTHORIZATION_PREFIX=Bearer
AUTH_CLIENT_SECRET_PREFIX=
AUTH_ENVIRONMENT=production
AUTH_MOCK_MODE=false

# --- Feature / behavior flags -----------------------------------------------
API_REQUIRE_AUTH=true
DEV_BYPASS_AUTH=false

SIMULATE_ANALYSIS=false
SIMULATE_ANALYSIS_DELAY_SECONDS=1

CELERY_TASK_ALWAYS_EAGER=false

# --- Session cookie security ------------------------------------------------
# In production (served via HTTPS behind Cloudflare Tunnel) these MUST be:
#   SESSION_COOKIE_SECURE=true
#   SESSION_COOKIE_SAMESITE=lax   (or "none" if embedding cross-site)
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_SAMESITE=lax
