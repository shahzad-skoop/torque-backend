APP_NAME=Torque Backend
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

DATABASE_URL=postgresql+psycopg2://torque:torque@postgres:5432/torque_backend
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

POSTGRES_DB=torque_backend
POSTGRES_USER=torque
POSTGRES_PASSWORD=torque

MINIO_ENDPOINT=minio:9000
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=torque-artifacts
MINIO_SECURE=false

AUTH_SERVICE_BASE_URL=https://auth-api.dev.skoopsignage.dev
AUTH_APP_SECRET=replace_me
AUTH_CLIENT_SECRET=replace_me
AUTH_AUTHORIZATION_PREFIX=Bearer
AUTH_CLIENT_SECRET_PREFIX=
AUTH_ENVIRONMENT=production
AUTH_MOCK_MODE=true

API_REQUIRE_AUTH=false
DEV_BYPASS_AUTH=true

SIMULATE_ANALYSIS=true
SIMULATE_ANALYSIS_DELAY_SECONDS=1

CELERY_TASK_ALWAYS_EAGER=false
